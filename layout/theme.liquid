{% section 'popup-subscribe' %}


<script>
(function () {
  const applyLabelFix = () => {
    document.querySelectorAll('label._formInputFieldLabel_1mxsl_38').forEach(label => {
      if (label.style.top !== '-10px') {
        label.style.top = '-10px';
      }
    });
  };

  // Run once in case it's already there
  applyLabelFix();

  // Watch for Shopify Forms injection & updates
  const observer = new MutationObserver(() => {
    applyLabelFix();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true,
    attributes: true,
    attributeFilter: ['style']
  });
})();
</script>



<script>
(function(){
  const freeShippingThreshold = 70; // Free shipping amount in dollars

  // Get all containers
  const containers = document.querySelectorAll('.freeshippingbar');
  if(!containers.length) return;

  containers.forEach(container => {
    // Create the bar inside each container
    container.style.position = "relative";
    container.innerHTML = `
      <div class="fv-bar" style="
        padding:12px;
        border-radius:8px;
        text-align:center;
        font-family:sans-serif;
        margin:40px auto;
      ">
        <span class="fv-message" style="font-weight:700;color:black;">
          Add £<span class="fv-amount">0</span> more to get free shipping! 🚚
        </span>
        <div style="
          background:#f1f1f1; 
          width:80%; 
          margin:8px auto; 
          height:10px; 
          border-radius:6px; 
          overflow:hidden;
        ">
          <div class="fv-progress" style="
            background:linear-gradient(90deg,#4caf50,#43a047); 
            height:100%; 
            width:0%; 
            transition:width 0.5s ease;
            display:block;
          "></div>
        </div>
      </div>
    `;

    const amountEl = container.querySelector('.fv-amount');
    const messageEl = container.querySelector('.fv-message');
    const progressEl = container.querySelector('.fv-progress');

    function updateBar(){
      fetch('/cart.js')
        .then(res => res.json())
        .then(cart => {
          const total = cart.items_subtotal_price / 100; // convert cents to dollars
          const remaining = Math.max(freeShippingThreshold - total, 0).toFixed(2);
          const progress = Math.min((total / freeShippingThreshold) * 100, 100);

          // Update progress bar
          progressEl.style.width = progress + '%';

          // Update message without breaking DOM
          if(total >= freeShippingThreshold){
            messageEl.innerText = "🎉 You got free shipping!";
          } else if(total >= freeShippingThreshold * 0.8){
            amountEl.innerText = remaining;
            messageEl.innerHTML = `Almost there! Only £<span class="fv-amount">${remaining}</span> left! 🔥`;
          } else {
            amountEl.innerText = remaining;
            messageEl.innerHTML = `Add £<span class="fv-amount">${remaining}</span> more to get free shipping! 🚚`;
          }
        });
    }

    // Initial update
    updateBar();

    // Update whenever Shopify cart changes
    document.addEventListener('cart:updated', updateBar);

    // Poll every 3 seconds in case event doesn't fire
    setInterval(updateBar, 3000);
  });

})();
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const waitForBundler = setInterval(() => {
    const buy1 = document.getElementById('_bndlr_radio_736107_1');
    const buy2 = document.getElementById('_bndlr_radio_736107_2');
    const buy3 = document.getElementById('_bndlr_radio_736107_3');
    const subs = document.getElementById('_bndlr_subs_checkbox_736107');

    if (!buy1 || !buy2 || !buy3 || !subs) return;

    clearInterval(waitForBundler);

    function syncSubscription() {
      if (buy1.checked) {
        subs.disabled = false;
        subs.closest('label')?.classList.remove('subs-disabled');
      } else {
        subs.checked = false; // Uncheck first
        subs.disabled = true; // Then disable
        subs.closest('label')?.classList.add('subs-disabled');
        
        // Trigger change event to update cart
        subs.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }

    buy1.addEventListener('change', syncSubscription);
    buy2.addEventListener('change', syncSubscription);
    buy3.addEventListener('change', syncSubscription);

    // Initial state
    syncSubscription();
  }, 200);
});
</script>

