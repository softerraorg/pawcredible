<script>
(function() {
  function initDynamicButton() {
    var widget = document.querySelector('.sealsubs-container');
    var btn = document.querySelector('.product-form__submit span');
    if (!widget || !btn) {
      setTimeout(initDynamicButton, 500);
      return;
    }

    function updateButtonText() {
      var activeSub = widget.querySelector('.sls-option-container[data-selling-plan-group].sls-active');
      if (activeSub) {
        var priceEl = activeSub.querySelector('.sls-price .money');
        var priceText = priceEl ? priceEl.textContent.trim() : '';
        btn.textContent = 'Start My Monthly Treat Plan' + (priceText ? ' \u2013 ' + priceText : '');
      } else {
        var otpEl = widget.querySelector('.sls-one-time-price .money');
        var otpText = otpEl ? otpEl.textContent.trim() : '';
        btn.textContent = 'Add to Cart' + (otpText ? ' \u2013 ' + otpText : '');
      }
    }

    updateButtonText();
    widget.addEventListener('click', function() { setTimeout(updateButtonText, 150); });
    widget.addEventListener('change', function() { setTimeout(updateButtonText, 150); });

    var observer = new MutationObserver(function() { setTimeout(updateButtonText, 100); });
    observer.observe(widget, { attributes: true, subtree: true, attributeFilter: ['class'] });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDynamicButton);
  } else {
    initDynamicButton();
  }
})();
</script>
