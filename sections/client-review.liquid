{% schema %}
{
  "name": "Testimonials Slider",
  "tag": "section",
  "class": "testimonials-slider",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "What Our Clients Say"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Client Testimonials"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "text", "id": "title", "label": "Title (h4)" },
        { "type": "textarea", "id": "review", "label": "Review Text" },
        { "type": "text", "id": "author", "label": "Author Name" },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        { "type": "text", "id": "product", "label": "Product Name" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Testimonials Slider" }]
}
{% endschema %}



<div class="testimonial-section text-center" id="testimonial-{{ section.id }}">
  <div class="testimonials-heading">
    {% if section.settings.sub_heading %}
    <p class="text-gray-500">{{ section.settings.sub_heading }}</p>
    {% endif %}
    {% if section.settings.heading %}
      <h2 class="text-3xl font-bold mb-6">{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  <div class="swiper testimonial-swiper-{{ section.id }}">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide">
          <div class="swiper-content">
            {% if block.settings.title %}
              <h4>{{ block.settings.title }}</h4>
            {% endif %}
            <span class="review-quotes">
              <svg width="24" height="17" viewBox="0 0 24 17" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M-8.99073e-07 5.46667C-8.3302e-07 4.71111 0.143054 4 0.42916 3.33333C0.69326 2.68889 1.0674 2.11111 1.55158 1.6C2.03576 1.11111 2.60798 0.722221 3.26823 0.433333C3.90647 0.144444 4.59973 2.11323e-07 5.348 2.76739e-07C6.29436 3.59472e-07 7.13067 0.211112 7.85695 0.633334C8.56121 1.05556 9.16644 1.6 9.67263 2.26667C10.1568 2.95556 10.5309 3.73333 10.795 4.6C11.0371 5.48889 11.1582 6.38889 11.1582 7.3C11.1582 8.3 11.0261 9.28889 10.762 10.2667C10.4979 11.2444 10.1238 12.1556 9.63961 13C9.13342 13.8444 8.51719 14.6111 7.79092 15.3C7.06465 15.9889 6.25034 16.5556 5.348 17L2.44292 15.4333C3.01513 14.8556 3.51032 14.1889 3.92847 13.4333C4.32462 12.6778 4.5227 11.8889 4.5227 11.0667L4.5227 10.7667C3.88446 10.6556 3.29023 10.4444 2.74003 10.1333C2.18982 9.82222 1.71664 9.43333 1.32049 8.96667C0.902337 8.5 0.583218 7.96667 0.363135 7.36667C0.121045 6.76667 -9.57355e-07 6.13333 -8.99073e-07 5.46667ZM12.8418 5.46667C12.8418 4.71111 12.9849 4 13.271 3.33333C13.5351 2.68889 13.9092 2.11111 14.3934 1.6C14.8776 1.11111 15.4498 0.722223 16.11 0.433334C16.7483 0.144445 17.4415 1.33399e-06 18.1898 1.39941e-06C19.1362 1.48214e-06 19.9725 0.211113 20.6988 0.633335C21.403 1.05556 22.0083 1.6 22.5144 2.26667C22.9986 2.95556 23.3728 3.73333 23.6369 4.6C23.879 5.48889 24 6.38889 24 7.3C24 8.3 23.868 9.28889 23.6039 10.2667C23.3398 11.2444 22.9656 12.1556 22.4814 13C21.9752 13.8444 21.359 14.6111 20.6327 15.3C19.9065 15.9889 19.0922 16.5556 18.1898 17L15.2847 15.4333C15.8569 14.8556 16.3521 14.1889 16.7703 13.4333C17.1664 12.6778 17.3645 11.8889 17.3645 11.0667L17.3645 10.7667C16.7263 10.6556 16.132 10.4444 15.5818 10.1333C15.0316 9.82222 14.5585 9.43333 14.1623 8.96667C13.7442 8.5 13.425 7.96667 13.205 7.36667C12.9629 6.76667 12.8418 6.13333 12.8418 5.46667Z" fill="#FDBE2E"/>
              </svg>
            </span>
            {% if block.settings.review %}
              <p class="review-content">{{ block.settings.review }}</p>
            {% endif %}
            {% if block.settings.author %}
              <p class="review-author">{{ block.settings.author }}</p>
            {% endif %}
            {% assign filled = block.settings.rating | plus: 0 %}
            {% assign empty = 5 | minus: filled %}
            <div class="review-star">
              {% for i in (1..filled) %}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.00001 0.333496L9.06001 4.50683L13.6667 5.18016L10.3333 8.42683L11.12 13.0135L7.00001 10.8468L2.88001 13.0135L3.66668 8.42683L0.333344 5.18016L4.94001 4.50683L7.00001 0.333496Z" fill="#FDBE2E"/>
                </svg>
              {% endfor %}
              {% for i in (1..empty) %}
              <span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.00001 0.333496L9.06001 4.50683L13.6667 5.18016L10.3333 8.42683L11.12 13.0135L7.00001 10.8468L2.88001 13.0135L3.66668 8.42683L0.333344 5.18016L4.94001 4.50683L7.00001 0.333496Z" fill="#FDBE2E"/>
                </svg>
              </span>{% endfor %}
            </div>
            {% if block.settings.product %}
              <p class="review-product-name"><span>Product:</span> {{ block.settings.product }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="review-arrows">
      <div class="swiper-button-prev">
      </div>
      <div class="swiper-button-next">
      </div>
    </div>
  </div>
</div>


<script>
  document.addEventListener("DOMContentLoaded", function () {
    new Swiper(".testimonial-swiper-{{ section.id }}", {
      slidesPerView: 4,
      spaceBetween: 20,
      autoplay: true,
      loop: true,
      navigation: {
        nextEl: ".testimonial-swiper-{{ section.id }} .swiper-button-next",
        prevEl: ".testimonial-swiper-{{ section.id }} .swiper-button-prev"
      },
      breakpoints: {
        320: { slidesPerView: 1 },
        640: { slidesPerView: 2 },
        1024: { slidesPerView: 3 },
        1280: { slidesPerView: 4 }
      }
    });
  });
</script>
