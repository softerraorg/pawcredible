{% schema %}
{
  "name": "Home About Section",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "about_image",
      "label": "About Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "Who We Are"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading (H2)",
      "default": "About Our Brand"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    }
  ],
  "presets": [
    {
      "name": "Home About",
      "category": "Home Custom Sections"
    }
  ]
}
{% endschema %}


<div class="custom-about-section">
  <div class="page-width">
    <div class="custom-about-wrap">
      <div class="about-image">
        {% if section.settings.about_image != blank %}
          <img src="{{ section.settings.about_image | img_url: '800x' }}" alt="About Image" />
        {% endif %}
      </div>
      <div class="about-content">
        <div class="subheading">{{ section.settings.subheading }}</div>
        <h2>{{ section.settings.heading }}</h2>
        <div class="rich-text">
          {{ section.settings.content }}
        </div>
      </div>
    </div>
  </div>
  
</div>
