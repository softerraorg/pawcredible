<section class="privacy-policy-heading">
  <div class="page-width">
    <h1>{{ section.settings.heading }}</h1>
  </div>
</section>

<section class="privacy-policy">
  <div class="page-width">
    {% if section.settings.content != blank %}
        <div class="rich-text">
          {{ section.settings.content }}
        </div>
      {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Privacy Policy",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Privacy Policy"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    }
  ],
  "presets": [
    {
      "name": "Privacy Policy",
      "category": "Privacy Policy"
    }
  ]
}
{% endschema %}