{{ 'feeding-calculator.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
{{ '//fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@600;700&display=swap' | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign handle_food = ''
  assign handle_topper = ''
  assign handle_treat = ''
  assign url_food = ''
  if section.settings.product_food != blank
    assign handle_food = section.settings.product_food.handle
    assign url_food = section.settings.product_food.url
  endif
  if section.settings.product_topper != blank
    assign handle_topper = section.settings.product_topper.handle
  endif
  if section.settings.product_treat != blank
    assign handle_treat = section.settings.product_treat.handle
  endif
-%}

<div
  class="feeding-calculator-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
  id="feeding-calculator-{{ section.id }}"
>
  <div class="page-width">
    <div
      class="feeding-calculator"
      data-feeding-calculator
      id="fc-root-{{ section.id }}"
      data-config-url="{{ 'feeding-calculator-config.json' | asset_url }}"
      data-money-format="{{ shop.money_format | escape }}"
      data-layout="{{ section.settings.layout }}"
      data-handle-food="{{ handle_food | escape }}"
      data-handle-topper="{{ handle_topper | escape }}"
      data-handle-treat="{{ handle_treat | escape }}"
      data-view-url="{{ url_food | escape }}"
      data-selling-plan-id="{{ section.settings.selling_plan_id | escape }}"
      data-label-view="{{ section.settings.label_view | escape }}"
      data-label-add-cart="{{ section.settings.label_add_cart | escape }}"
      data-label-add-subscribe="{{ section.settings.label_add_subscribe | escape }}"
      data-hint-subscribe-plan="{{ section.settings.hint_subscribe_plan | escape }}"
      data-msg-cart-incomplete="{{ section.settings.msg_cart_incomplete | escape }}"
      data-msg-cart-error="{{ section.settings.msg_cart_error | escape }}"
      data-label-weight="{{ section.settings.label_weight | escape }}"
      data-hint-weight="{{ section.settings.hint_weight | escape }}"
      data-weight-min="0"
      data-weight-max="100"
      data-label-activity="{{ section.settings.label_activity | escape }}"
      data-hint-activity="{{ section.settings.hint_activity | escape }}"
      data-label-continue="{{ section.settings.label_continue | escape }}"
      data-label-see="{{ section.settings.label_see | escape }}"
      data-label-back="{{ section.settings.label_back | escape }}"
      data-label-daily-grams="{{ section.settings.label_daily_grams | escape }}"
      data-label-monthly="{{ section.settings.label_monthly | escape }}"
      data-label-purchase="{{ section.settings.label_purchase | escape }}"
      data-label-subscribe="{{ section.settings.label_subscribe | escape }}"
      data-label-onetime="{{ section.settings.label_onetime | escape }}"
      data-label-off="{{ section.settings.label_off | escape }}"
      data-label-daily-sub="{{ section.settings.label_daily_sub | escape }}"
      data-label-daily-once="{{ section.settings.label_daily_once | escape }}"
      data-label-day="{{ section.settings.label_day | escape }}"
      data-label-one-time-compare="{{ section.settings.label_one_time_compare | escape }}"
      data-label-sub-compare="{{ section.settings.label_sub_compare | escape }}"
      data-label-recalc="{{ section.settings.label_recalc | escape }}"
      data-label-close="{{ section.settings.label_close | escape }}"
      data-msg-extra-bag="{{ section.settings.msg_extra_bag | escape }}"
      data-msg-bumped="{{ section.settings.msg_bumped | escape }}"
      data-label-step1-title="{{ section.settings.label_step1_title | escape }}"
      data-hint-build="{{ section.settings.hint_build | escape }}"
      data-label-dog-name="{{ section.settings.label_dog_name | escape }}"
      data-label-dog-breed="{{ section.settings.label_dog_breed | escape }}"
      data-placeholder-dog-name="{{ section.settings.placeholder_dog_name | escape }}"
      data-placeholder-dog-breed="{{ section.settings.placeholder_dog_breed | escape }}"
      data-label-activity-heading="{{ section.settings.label_activity_heading | escape }}"
      data-label-plan-possessive="{{ section.settings.label_plan_possessive | escape }}"
      data-label-plan-no-name="{{ section.settings.label_plan_no_name | escape }}"
      data-default-breed-word="{{ section.settings.default_breed_word | escape }}"
      data-msg-based-on="{{ section.settings.msg_based_on | escape }}"
      data-msg-ideal-plan="{{ section.settings.msg_ideal_plan | escape }}"
      data-label-feeding-guide="{{ section.settings.label_feeding_guide | escape }}"
      data-label-benefits="{{ section.settings.label_benefits | escape }}"
      data-subscribe-benefits="{{ section.settings.subscribe_benefits | escape }}"
      data-subscribe-benefits-pills="{{ section.settings.subscribe_benefits_pills | escape }}"
      data-label-recommended-bundle="{{ section.settings.label_recommended_bundle | escape }}"
      data-label-loading-plan="{{ section.settings.label_loading_plan | escape }}"
      data-label-intro-title="{{ section.settings.label_intro_title | escape }}"
      data-label-intro-copy="{{ section.settings.label_intro_copy | escape }}"
      data-label-start-calc="{{ section.settings.label_start_calc | escape }}"
      data-label-step-counter="{{ section.settings.label_step_counter | escape }}"
      data-label-q-name="{{ section.settings.label_q_name | escape }}"
      data-hint-q-name="{{ section.settings.hint_q_name | escape }}"
      data-label-q-breed="{{ section.settings.label_q_breed | escape }}"
      data-hint-q-breed="{{ section.settings.hint_q_breed | escape }}"
      data-placeholder-breed-search="{{ section.settings.placeholder_breed_search | escape }}"
      data-label-use-breed="{{ section.settings.label_use_breed | escape }}"
      data-label-q-weight="{{ section.settings.label_q_weight | escape }}"
      data-label-q-activity="{{ section.settings.label_q_activity | escape }}"
      data-hint-q-activity="{{ section.settings.hint_q_activity | escape }}"
      data-label-see-plan-name="{{ section.settings.label_see_plan_name | escape }}"
      data-msg-based-on-being="{{ section.settings.msg_based_on_being | escape }}"
      data-label-feeding-plan-for="{{ section.settings.label_feeding_plan_for | escape }}"
      data-label-feed-from="{{ section.settings.label_feed_from | escape }}"
      data-label-choose-pack="{{ section.settings.label_choose_pack | escape }}"
      data-label-subscribe-sub="{{ section.settings.label_subscribe_sub | escape }}"
      data-label-best-value="{{ section.settings.label_best_value | escape }}"
      data-label-cta-sub="{{ section.settings.label_cta_sub | escape }}"
      data-label-cta-once="{{ section.settings.label_cta_once | escape }}"
      data-label-cta-foot-sub="{{ section.settings.label_cta_foot_sub | escape }}"
      data-label-cta-foot-once="{{ section.settings.label_cta_foot_once | escape }}"
      data-label-results-header="{{ section.settings.label_results_header | escape }}"
      data-badge-recommended="{{ section.settings.badge_recommended | escape }}"
      data-default-dog-call="{{ section.settings.default_dog_call | escape }}"
      data-loading-sub-1="{{ section.settings.loading_sub_1 | escape }}"
      data-loading-sub-2="{{ section.settings.loading_sub_2 | escape }}"
      data-loading-sub-3="{{ section.settings.loading_sub_3 | escape }}"
      data-loading-sub-4="{{ section.settings.loading_sub_4 | escape }}"
    >
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="feeding-calculator__intro">
          {%- if section.settings.heading != blank -%}
            <h2 class="inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p>{{ section.settings.subheading | escape }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.layout == 'modal' -%}
        <div style="text-align: center;">
          <button
            type="button"
            class="button feeding-calculator__open"
            data-feeding-open
          >
            {{ section.settings.open_button_label | escape }}
          </button>
        </div>
        <div class="feeding-calculator__backdrop" data-feeding-modal hidden>
          <div class="feeding-calculator__sheet" role="dialog" aria-modal="true" aria-labelledby="fc-title-{{ section.id }}">
            <div class="feeding-calculator__sheet-header">
              <span id="fc-title-{{ section.id }}" class="visually-hidden">{{ section.settings.heading | default: 'Feeding calculator' | escape }}</span>
              <span></span>
              <button type="button" class="feeding-calculator__close" data-feeding-close aria-label="{{ 'accessibility.close' | t | escape }}">×</button>
            </div>
            <div class="feeding-calculator__panel" data-feeding-panel>
              <p class="feeding-calculator__muted" style="margin:0;">{{ 'accessibility.loading' | t }}</p>
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="feeding-calculator__panel" data-feeding-panel>
          <p class="feeding-calculator__muted" style="margin:0;">{{ section.settings.loading_text | escape }}</p>
        </div>
      {%- endif -%}

      <div class="feeding-calculator__error" data-feeding-error hidden>
        {{ section.settings.error_text | escape }}
      </div>
    </div>
  </div>
</div>

<script src="{{ 'feeding-calculator.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Feeding calculator",
  "tag": "section",
  "class": "section-feeding-calculator",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Build Your Dog's Personal Feeding Plan"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h1", "label": "H1" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tell us about your dog — we’ll tailor bags, toppers, treats, and daily grams."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "inline", "label": "Inline (on page)" },
        { "value": "modal", "label": "Button opens modal" }
      ],
      "default": "inline"
    },
    {
      "type": "text",
      "id": "open_button_label",
      "label": "Open button (modal layout)",
      "default": "Start feeding calculator"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading text (inline)",
      "default": "Loading calculator…"
    },
    {
      "type": "text",
      "id": "error_text",
      "label": "Error message",
      "default": "Could not load calculator config. Please refresh the page."
    },
    {
      "type": "header",
      "content": "Pack products"
    },
    {
      "type": "paragraph",
      "content": "Prices and Add to cart use these three products: food bags, topper tubes, and treat pouches, with quantities from the selected pack tier."
    },
    {
      "type": "product",
      "id": "product_food",
      "label": "BioBowl / main food product"
    },
    {
      "type": "product",
      "id": "product_topper",
      "label": "Raw Fusion Topper product"
    },
    {
      "type": "product",
      "id": "product_treat",
      "label": "Raw Fusion Treat product"
    },
    {
      "type": "text",
      "id": "selling_plan_id",
      "label": "Selling plan ID (optional)",
      "info": "Shopify Admin → product → Purchase options → open the plan → ID in URL or app. Each component (food, topper, treat) should include this plan when Subscribe is selected."
    },
    {
      "type": "header",
      "content": "Cart button labels"
    },
    {
      "type": "text",
      "id": "label_view",
      "label": "View product link",
      "default": "View product"
    },
    {
      "type": "text",
      "id": "label_add_cart",
      "label": "Add pack (one-time)",
      "default": "Add pack to cart"
    },
    {
      "type": "text",
      "id": "label_add_subscribe",
      "label": "Add pack (subscribe)",
      "default": "Subscribe & add pack"
    },
    {
      "type": "text",
