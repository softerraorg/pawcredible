<section class="blog-feature-section page-width">
  <h1>{{ section.settings.heading }}</h1>
  <div class="blog-feature-grid">

    <!-- Left Blog Post -->
    {% assign left_blog = blogs[section.settings.left_blog] %}
    {% assign left_article = left_blog.articles.first %}
    {% if left_article %}
    <div class="blog-col random-post-left">
      <div class="blog-card">
        <a href="{{ left_article.url }}" class="blog-feature-img">
          <img src="{{ left_article.image | image_url: width: 600 }}" alt="{{ left_article.title }}">
        </a>
        <a href="{{ left_blog.url }}" class="blog-category">{{ left_blog.title }}</a>
        <h3><a href="{{ left_article.url }}">{{ left_article.title }}</a></h3>
        <p class="post-date">{{ left_article.published_at | date: "%B %d, %Y" }}</p>
        <p class="excerpt">{{ left_article.excerpt | default: left_article.content | strip_html | truncatewords: 20 }}</p>
      </div>
    </div>
    {% endif %}

    <!-- Right Blog Post -->
    {% assign right_blog = blogs[section.settings.right_blog] %}
    {% assign right_article = right_blog.articles.first %}
    {% if right_article %}
    <div class="blog-col random-post-right">
      <div class="blog-card">
        <a href="{{ right_article.url }}" class="blog-feature-img">
          <img src="{{ right_article.image | image_url: width: 600 }}" alt="{{ right_article.title }}">
        </a>
        <a href="{{ right_blog.url }}" class="blog-category">{{ right_blog.title }}</a>
        <h3><a href="{{ right_article.url }}">{{ right_article.title }}</a></h3>
        <p class="post-date">{{ right_article.published_at | date: "%B %d, %Y" }}</p>
        <p class="excerpt">{{ right_article.excerpt | default: right_article.content | strip_html | truncatewords: 20 }}</p>
      </div>
    </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Blog Feature Section",
  "settings": [
    {
      "type": "blog",
      "id": "left_blog",
      "label": "Select Left Blog"
    },
    {
      "type": "blog",
      "id": "right_blog",
      "label": "Select Right Blog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Blog"
    }
  ],
  "presets": [
    {
      "name": "Blog Feature Section"
    }
  ]
}
{% endschema %}