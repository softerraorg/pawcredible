<section class="content-process-section">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="process-grid">
      {% for block in section.blocks %}
        {% if block.type == 'process' %}
          <div class="process-item">
            {% if block.settings.image != blank %}
              <div class="process-img">
                <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.title }}" loading="lazy">
              </div>
            {% endif %}
            <h4>{{ block.settings.title }}</h4>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="process-extra-content">
      {% if section.settings.extra_heading != blank %}
        <h3>{{ section.settings.extra_heading }}</h3>
      {% endif %}
      {% if section.settings.extra_text != blank %}
        <p>{{ section.settings.extra_text }}</p>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Our Story Process",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "extra_heading",
      "label": "Extra Section Heading (H3)",
      "default": "Why Choose Us"
    },
    {
      "type": "textarea",
      "id": "extra_text",
      "label": "Extra Section Paragraph",
      "default": "We provide quality and value at every step."
    }
  ],
  "blocks": [
    {
      "type": "process",
      "name": "Process Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Process Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Process Title (H4)",
          "default": "Step Title"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Our Story Process",
      "category": "Our Story"
    }
  ]
}
{% endschema %}