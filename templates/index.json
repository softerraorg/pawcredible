            "product": "Pawcredible BioBowl Chicken Kibble"
          }
        },
        "testimonial_PJ7Ya3": {
          "type": "testimonial",
          "settings": {
            "title": "Finally Something My Picky Eater Loves",
            "review": "Our senior Shih Tzu, Boomer, turns down almost everything… except this topper. He’s gained healthy weight back and even waits by his bowl now. Absolutely worth it.",
            "author": "Kevin R",
            "rating": 5,
            "product": "Freeze-Dried Raw Chicken Topper"
