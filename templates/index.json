    "faqs_section_Eywinh": {
      "type": "faqs-section",
      "blocks": {
        "faq_item_LDpGVJ": {
          "type": "faq_item",
          "settings": {
            "question": "1. What makes Pawcredible different?",
            "answer": "<p>For our Paws in the UK and EU, all Pawcredible products are proudly made in the United Kingdom, meeting strict quality and safety standards.</p><p>For our Paws in North America, Pawcredible products are produced right in the US, ensuring freshness and compliance with local regulations.</p><p>Wherever your dog calls home, you can trust that every Pawcredible product is made with care, premium ingredients, and your dog’s health in mind!</p>"
          }
        },
        "faq_item_bYDXFi": {
          "type": "faq_item",
          "settings": {
            "question": "2. What is BioBowl Fusion?",
            "answer": "<p>BioBowl Fusion is our complete premium meal, blending our high-quality kibble with our freeze-dried raw coating. It delivers the taste and nutrition of raw feeding with the<br/>convenience of dry food, no freezer, no mess, just open, pour, and serve.</p>"
          }
        },
        "faq_item_PrC6Bx": {
          "type": "faq_item",
          "settings": {
            "question": "3. What is Raw Fusion?",
            "answer": "<p>Raw Fusion is our freeze-dried raw topper and treat range; also, our premium kibble is<br/>coated with our Raw Fusion topper. Packed with protein and nutrients from 100%<br/>natural ingredients, adding a burst of flavour and nourishment to every meal.</p>"
          }
        },
        "faq_item_gPYRkc": {
          "type": "faq_item",
          "settings": {
            "question": "4. What is Bioavailability?",
            "answer": "<p>Bioavailability is how well your dog’s body can absorb and use the nutrients in their<br/>food. It’s not just about what’s in the bowl - it’s about what actually gets digested and<br/>turned into energy, strength, and health.<br/></p><p>At Pawcredible, every ingredient is chosen for maximum bioavailability - from fresh<br/>meats and superfoods to natural oils and vitamins, so your dog gets real nutritional<br/>benefits from every bite, not wasted fillers.</p>"
          }
        }
      },
      "block_order": [
        "faq_item_LDpGVJ",
        "faq_item_bYDXFi",
