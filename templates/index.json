        },
        "testimonial_D6G9Db": {
          "type": "testimonial",
          "settings": {
            "title": "Finally a Kibble My Dog Is Excited About",
            "review": "Our miniature schnauzer, Penny, has never run to her bowl… until we found this kibble. She genuinely looks thrilled every time we pour it out. Her digestion has been smoother and her coat feels softer. This stuff is staying on our shelf permanently.",
            "author": "Danielle H",
            "rating": 5,
            "product": "BioBowl Fusion"
          }
        },
        "testimonial_DamqxT": {
          "type": "testimonial",
          "settings": {
            "title": "High-Value Treats That Actually Work",
            "review": "We’ve tried so many treats for training, but nothing grabs our Beagle’s attention like these freeze-dried bites. They don’t feel or look plasticky, they smell like real food, and our dog will literally teleport across the room for them. Makes training way easier.",
            "author": "Mark E",
            "rating": 5,
            "product": "Freeze-Dried Treats"
          }
        },
        "testimonial_Kh8BLY": {
          "type": "testimonial",
          "settings": {
            "title": "Perfect Combo for Everyday Feeding",
            "review": "We use the BioBowl Fusion for our daily meals and the freeze-dried treats as rewards throughout the day. The quality is consistent across both, clean ingredients, great smell, and our Aussie Shepherd goes crazy for them.",
