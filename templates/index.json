    "custom_review_9BgeqY": {
      "type": "custom-review",
      "blocks": {
        "review_gk3mqY": {
          "type": "review",
          "settings": {
            "client_title": "Owners of a 5-year old Vizsla named Finn",
            "name": "Daniel & Brooke Mercer",
            "designation": "",
            "review": "We hike with Finn a few times a week, and finding food that keeps his energy up without upsetting his stomach has always been tricky. We were lucky enough to get early access to Pawcredible a couple of months ago and honestly, the difference has been noticeable. He’s got more stamina, his paws don’t get dry like they used to, and he genuinely perks up when we open the bag. We take the treat pouch on every long hike now."
          }
        },
        "review_bwC6jH": {
          "type": "review",
          "settings": {
            "client_title": "Owner of an athletic Border Collie named Jasper",
            "name": "Marcus Boyd",
            "designation": "",
            "review": "I’m pretty careful about what I eat, so it made sense to start paying the same attention to Jasper’s food too. What stood out with Pawcredible was the balance, good quality protein without a load of unnecessary filler. He’s holding his muscle better, seems to recover faster after agility training, and his coat has a healthy shine to it now. The freeze-dried pieces feel like a proper boost for him. I’d happily recommend it to anyone with an active dog."
          }
        },
        "review_qkfpYX": {
          "type": "review",
          "settings": {
            "client_title": "Owner of a 1-year-old Frenchie named Luna",
            "name": "Sophie Whitman",
            "designation": "",
            "review": "As a first-time dog mum I definitely over-research everything, so feeling confident about Luna’s food really mattered to me. Pawcredible won me over because I could actually recognise the ingredients, nothing weird or overcomplicated. She used to pick at her meals, but now she gets genuinely excited when she sees me reach for the bag. Even her tear stains have eased a lot, which her groomer pointed out before I even noticed."
          }
        },
        "review_HExwHx": {
          "type": "review",
          "settings": {
            "client_title": "Owner of a 12-year-old Golden Retriever named Daisy",
            "name": "Helen Foster",
            "designation": "",
            "review": "Daisy’s in her senior years now, so we’re much more careful about what she eats. A lot of kibble has been too harsh on her stomach or just difficult for her to chew. Getting early access to Pawcredible honestly felt like a bit of luck. It’s gentle on her digestion, she eats it without fuss, and the topper really helps her finish her meals without any encouragement. She seems more comfortable getting up in the mornings and is moving a little easier again. It’s been really nice to see that spark come back."
          }
        },
        "review_Xi7WCQ": {
          "type": "review",
          "settings": {
            "client_title": "Owner of a 3-year-old Cavapoo named Milo",
            "name": "Emily Hartwell",
            "designation": "",
            "review": "Milo’s stomach has always been a bit on the dramatic side. We’ve tried so many foods over the years that it felt like nothing was ever quite right. Pawcredible is the first one that didn’t lead to restless nights or an unsettled stomach. He finishes his bowl without thinking twice now, his coat looks healthier, and his energy stays steady through the day instead of coming in peaks and crashes. Honestly, it’s been such a relief to finally find something that works for him"
          }
        },
        "review_NYejLd": {
          "type": "review",
          "settings": {
            "client_title": "Owner of four mixed-breed rescues",
            "name": "Karen Delgado",
            "designation": "",
            "review": "Our house is basically run by four dogs with very strong opinions. Getting them all to agree on the same food felt impossible until Pawcredible. Even the oldest one, who’s known for turning his nose up at anything that isn’t roast chicken eats it without any fuss. I also like that it’s clean and not greasy, and it actually smells like real food. Feeding time is a lot less stressful now."
          }
        }
