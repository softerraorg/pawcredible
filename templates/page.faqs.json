        "faq_left_cpEigw": {
          "type": "faq_left",
          "settings": {
            "question": "1. What makes Pawcredible different?",
            "answer": "Pawcredible combines science and nature to create real, bioavailable nutrition your dog\ncan actually absorb. Our meals, treats, and toppers are made in the UK with premium\nsourced ingredients, no fillers, no artificial nasties, and no frozen storage required."
          }
        },
        "faq_left_CFnaJt": {
          "type": "faq_left",
          "settings": {
            "question": "2. What is BioBowl Fusion?",
            "answer": "BioBowl Fusion is our complete premium meal, blending our high-quality kibble with our freeze-dried raw coating. It delivers the taste and nutrition of raw feeding with the\nconvenience of dry food, no freezer, no mess, just open, pour, and serve."
          }
        },
        "faq_left_UEQwhJ": {
          "type": "faq_left",
          "settings": {
            "question": "3. What is Raw Fusion?",
            "answer": "Raw Fusion is our freeze-dried raw topper and treat range; also, our premium kibble is\ncoated with our Raw Fusion topper. Packed with protein and nutrients from 100%\nnatural ingredients, adding a burst of flavour and nourishment to every meal."
          }
        },
        "faq_left_XgitNc": {
          "type": "faq_left",
          "settings": {
            "question": "4. What is Bioavailability?",
            "answer": "Bioavailability is how well your dog’s body can absorb and use the nutrients in their\nfood. It’s not just about what’s in the bowl - it’s about what actually gets digested and\nturned into energy, strength, and health.\n\nAt Pawcredible, every ingredient is chosen for maximum bioavailability - from fresh\nmeats and superfoods to natural oils and vitamins, so your dog gets real nutritional\nbenefits from every bite, not wasted fillers."
          }
        },
        "faq_left_63xwQ7": {
          "type": "faq_left",
          "settings": {
            "question": "5. How do I serve Pawcredible products?",
            "answer": "Simply pour BioBowl Fusion straight into your dog’s bowl - just like a normal kibble\nmeal.\nFor our Raw Fusion toppers, sprinkle the suggested spoonful over your dog’s meal for\nadded taste and nutrition. Treats can be given anytime as a healthy reward, but can\nalso be mixed into your dog's kibble meals for extra nutrition."
          }
        },
        "faq_left_3kjRdt": {
          "type": "faq_left",
          "settings": {
            "question": "6. Where are your products made?",
            "answer": "All Pawcredible products are made in the UK, using responsibly sourced meats and\ningredients from trusted suppliers that meet our strict quality and welfare standards."
          }
        },
        "faq_right_qArqBe": {
          "type": "faq_right",
          "settings": {
            "question": "7. Are your products suitable for all breeds and sizes?",
            "answer": "Yes! Pawcredible recipes are formulated for all breeds and life stages. We focus on\ncomplete, balanced nutrition that supports digestion, muscle health, skin, coat, and\noverall vitality for dogs big and small."
          }
        },
        "faq_right_tr3Q6r": {
          "type": "faq_right",
          "settings": {
            "question": "8. Do your products contain grains?",
            "answer": "Our BioBowl Fusion recipes are grain-free, using sweet potato, pumpkin, and other\nwholesome carbohydrates for sustained energy."
          }
        },
        "faq_right_xXmq67": {
          "type": "faq_right",
          "settings": {
            "question": "9. Do you offer subscriptions?",
            "answer": "Yes! You can subscribe and save on your dog’s favourite meals and treats - with flexible delivery schedules you can pause, skip, or cancel anytime through your account."
          }
        },
        "faq_right_Kf7wXN": {
          "type": "faq_right",
          "settings": {
            "question": "10. What’s your return policy?",
            "answer": "If something’s not right, please contact us within 14 days of receiving your order. We’ll\nhelp make it right - whether that’s a replacement, refund, or store credit. We’re only happy when your dog’s tail is wagging."
          }
        },
